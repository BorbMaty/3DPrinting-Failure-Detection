<mxfile host="app.diagrams.net" modified="2026-04-04" version="21.0.0">
  <diagram name="MediaMTX Stream Pipeline" id="mediamtx-pipeline">
    <mxGraphModel dx="1600" dy="950" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============ TITLE ============ -->
        <mxCell id="title" value="MediaMTX Streaming Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="480" y="15" width="500" height="35" as="geometry" />
        </mxCell>

        <!-- ============ CAMERAS ============ -->
        <mxCell id="cam_group" value="USB Camera Sources" style="swimlane;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;startSize=25;rounded=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="200" height="260" as="geometry" />
        </mxCell>
        <mxCell id="cam1" value="&lt;b&gt;Camera 1&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;/dev/video0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="cam_group">
          <mxGeometry x="25" y="40" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="cam2" value="&lt;b&gt;Camera 2&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;/dev/video2&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="cam_group">
          <mxGeometry x="25" y="105" width="150" height="45" as="geometry" />
        </mxCell>
        <mxCell id="cam3" value="&lt;b&gt;Camera 3&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;/dev/video4&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;shadow=1;" vertex="1" parent="cam_group">
          <mxGeometry x="25" y="170" width="150" height="45" as="geometry" />
        </mxCell>

        <!-- ============ MEDIAMTX SERVER ============ -->
        <mxCell id="mtx_group" value="MediaMTX Server (Docker Container on Raspberry Pi)" style="swimlane;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;startSize=25;rounded=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="380" height="380" as="geometry" />
        </mxCell>

        <!-- Base image info -->
        <mxCell id="mtx_base" value="&lt;font style=&quot;font-size:9px&quot;&gt;bluenviron/mediamtx:latest | user: 65534 (nobody)&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=9;fontColor=#666666;" vertex="1" parent="mtx_group">
          <mxGeometry x="10" y="28" width="360" height="15" as="geometry" />
        </mxCell>

        <!-- RTSP Receiver -->
        <mxCell id="rtsp_in" value="&lt;b&gt;RTSP Receiver&lt;/b&gt;&lt;br&gt;Port :8554&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Accepts publisher connections&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="mtx_group">
          <mxGeometry x="20" y="55" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Path routing -->
        <mxCell id="path_router" value="&lt;b&gt;Path Router&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;/cam1 → source: publisher&lt;br&gt;/cam2 → source: publisher&lt;br&gt;/cam3 → source: publisher&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="mtx_group">
          <mxGeometry x="110" y="145" width="170" height="75" as="geometry" />
        </mxCell>

        <!-- Protocol outputs -->
        <mxCell id="rtsp_out" value="&lt;b&gt;RTSP&lt;/b&gt;&lt;br&gt;:8554" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="mtx_group">
          <mxGeometry x="20" y="260" width="75" height="45" as="geometry" />
        </mxCell>
        <mxCell id="rtmp_out" value="&lt;b&gt;RTMP&lt;/b&gt;&lt;br&gt;:8080" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;shadow=1;" vertex="1" parent="mtx_group">
          <mxGeometry x="105" y="260" width="70" height="45" as="geometry" />
        </mxCell>
        <mxCell id="webrtc_out" value="&lt;b&gt;WebRTC&lt;/b&gt;&lt;br&gt;WHEP :8889" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;shadow=1;" vertex="1" parent="mtx_group">
          <mxGeometry x="185" y="260" width="85" height="45" as="geometry" />
        </mxCell>
        <mxCell id="hls_out" value="&lt;b&gt;HLS&lt;/b&gt;&lt;br&gt;:8888" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;shadow=1;" vertex="1" parent="mtx_group">
          <mxGeometry x="280" y="260" width="70" height="45" as="geometry" />
        </mxCell>

        <!-- Health check -->
        <mxCell id="healthcheck" value="&lt;font style=&quot;font-size:9px&quot;&gt;Health Check: HTTP GET :8889 every 30s | Ports exposed: 8554, 8080, 8888, 8889, 8890&lt;/font&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=9;fontColor=#666666;" vertex="1" parent="mtx_group">
          <mxGeometry x="10" y="330" width="360" height="15" as="geometry" />
        </mxCell>

        <!-- Internal edges -->
        <mxCell id="me1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="rtsp_in" target="path_router" parent="mtx_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="path_router" target="rtsp_out" parent="mtx_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me2b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;" edge="1" source="path_router" target="rtmp_out" parent="mtx_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;" edge="1" source="path_router" target="webrtc_out" parent="mtx_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="me4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#999999;" edge="1" source="path_router" target="hls_out" parent="mtx_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ OUTPUT PATH 1: Frame Extractor ============ -->
        <mxCell id="fe_group" value="Frame Extractor (Python 3.12 on Raspberry Pi)" style="swimlane;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;startSize=25;rounded=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="70" width="260" height="200" as="geometry" />
        </mxCell>
        <mxCell id="fe_rtsp" value="&lt;b&gt;RTSP Client&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;cv2.VideoCapture()&lt;br&gt;rtsp://localhost:8554/cam{1,2,3}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;shadow=1;" vertex="1" parent="fe_group">
          <mxGeometry x="20" y="35" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fe_encode" value="&lt;b&gt;JPEG Encode + Base64&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;640x480 | Quality 70 | 2 FPS&lt;br&gt;One thread per camera&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="fe_group">
          <mxGeometry x="20" y="110" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="fe_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" source="fe_rtsp" target="fe_encode" parent="fe_group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pub/Sub -->
        <mxCell id="pubsub_out" value="&lt;b&gt;Google Cloud Pub/Sub&lt;/b&gt;&lt;br&gt;Topic: frames-in&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Payload: {camera_id, seq, ts, data_b64}&lt;br&gt;Retention: 1 hour&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="310" width="230" height="65" as="geometry" />
        </mxCell>

        <!-- GCP Detection Pipeline -->
        <mxCell id="gcp_pipeline" value="&lt;b&gt;GCP Detection Pipeline&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Dispatcher → Vertex AI (YOLOv8x)&lt;br&gt;→ detections-out → Alert Manager&lt;br&gt;→ Firestore + Email + FCM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="310" width="230" height="65" as="geometry" />
        </mxCell>

        <!-- ============ OUTPUT PATH 2: WebRTC → Browser ============ -->
        <mxCell id="cf_tun" value="&lt;b&gt;Cloudflare Tunnel&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;cloudflared daemon on Pi&lt;br&gt;Maps :8889 → public HTTPS URL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="430" width="260" height="55" as="geometry" />
        </mxCell>

        <!-- Internet -->
        <mxCell id="internet" value="Internet" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=11;dashed=1;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="430" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Browser Dashboard -->
        <mxCell id="browser" value="&lt;b&gt;Browser Dashboard&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Firebase Hosting SPA&lt;br&gt;WebRTC WHEP Player (3 streams)&lt;br&gt;Canvas overlay for bounding boxes&lt;br&gt;printermonitor-488112.web.app&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1280" y="415" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- ============ CROSS EDGES ============ -->

        <!-- Cameras → MediaMTX RTSP input -->
        <mxCell id="ce1" value="USB stream" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="cam1" target="rtsp_in" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;fontSize=9;strokeWidth=2;" edge="1" source="cam2" target="rtsp_in" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ce3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#6c8ebf;fontSize=9;strokeWidth=2;" edge="1" source="cam3" target="rtsp_in" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- RTSP output → Frame Extractor -->
        <mxCell id="ce4" value="RTSP pull :8554" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="rtsp_out" target="fe_rtsp" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="720" y="355" />
              <mxPoint x="720" y="60" />
              <mxPoint x="880" y="60" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Frame Extractor → Pub/Sub -->
        <mxCell id="ce5" value="publish base64 JPEG" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="fe_encode" target="pubsub_out" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Pub/Sub → GCP pipeline -->
        <mxCell id="ce5b" value="Eventarc trigger" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d79b00;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="pubsub_out" target="gcp_pipeline" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- WebRTC → Cloudflare Tunnel -->
        <mxCell id="ce6" value="WebRTC WHEP :8889" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="webrtc_out" target="cf_tun" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Cloudflare → Internet -->
        <mxCell id="ce7" value="HTTPS tunnel" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="cf_tun" target="internet" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Internet → Browser -->
        <mxCell id="ce8" value="WebRTC WHEP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;fontSize=9;fontColor=#333333;strokeWidth=2;" edge="1" source="internet" target="browser" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============ LEGEND ============ -->
        <mxCell id="legend" value="&lt;b&gt;Data Flow Paths&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;&lt;font color=&quot;#6c8ebf&quot;&gt;Blue&lt;/font&gt; = USB camera input&lt;br&gt;&lt;font color=&quot;#82b366&quot;&gt;Green&lt;/font&gt; = RTSP stream (internal)&lt;br&gt;&lt;font color=&quot;#9673a6&quot;&gt;Purple&lt;/font&gt; = WebRTC output (live view)&lt;br&gt;&lt;font color=&quot;#d79b00&quot;&gt;Orange&lt;/font&gt; = Pub/Sub (detection pipeline)&lt;br&gt;&lt;font color=&quot;#b85450&quot;&gt;Red&lt;/font&gt; = Cloudflare tunnel (public access)&lt;br&gt;&lt;font color=&quot;#999999&quot;&gt;Grey&lt;/font&gt; = Available but unused protocols&lt;/font&gt;" style="text;html=1;strokeColor=#999999;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;dashed=1;fontSize=10;spacingLeft=6;spacingTop=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="380" width="250" height="130" as="geometry" />
        </mxCell>

        <!-- ============ DUAL PATH ANNOTATION ============ -->
        <mxCell id="path_note" value="&lt;b&gt;Two Parallel Data Paths&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px&quot;&gt;Path 1 (top): RTSP → Frame Extractor → Pub/Sub → GCP AI inference&lt;br&gt;Path 2 (bottom): WebRTC → Cloudflare → Browser (live monitoring)&lt;/font&gt;" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=10;spacingLeft=6;spacingTop=4;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="540" width="400" height="55" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
