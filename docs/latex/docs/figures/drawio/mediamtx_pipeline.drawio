<mxfile host="app.diagrams.net" modified="2026-04-06" version="21.0.0">
  <diagram name="MediaMTX Pipeline" id="mediamtx-pipeline">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="585" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="MediaMTX Streaming Pipeline" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="10" width="480" height="25" as="geometry" />
        </mxCell>

        <!-- Cameras -->
        <mxCell id="cam1" value="Camera 1&#xa;/dev/video0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="70" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cam2" value="Camera 2&#xa;/dev/video2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="cam3" value="Camera 3&#xa;/dev/video4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="230" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- MediaMTX -->
        <mxCell id="mtx" value="MediaMTX Server&#xa;(Docker, Raspberry Pi)" style="swimlane;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;startSize=26;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="210" y="70" width="250" height="260" as="geometry" />
        </mxCell>
        <mxCell id="rtspin" value="RTSP Receiver&#xa;:8554" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="mtx">
          <mxGeometry x="60" y="40" width="130" height="45" as="geometry" />
        </mxCell>
        <mxCell id="router" value="Path Router&#xa;/cam1  /cam2  /cam3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="mtx">
          <mxGeometry x="50" y="105" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rtspout" value="RTSP :8554" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="mtx">
          <mxGeometry x="15" y="185" width="105" height="45" as="geometry" />
        </mxCell>
        <mxCell id="webrtc" value="WebRTC :8889" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="mtx">
          <mxGeometry x="130" y="185" width="105" height="45" as="geometry" />
        </mxCell>
        <mxCell id="mi1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="rtspin" target="router" parent="mtx"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="mi2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="router" target="rtspout" parent="mtx"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="mi3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="router" target="webrtc" parent="mtx"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Frame Extractor -->
        <mxCell id="fe" value="Frame Extractor&#xa;Python, 2 FPS&#xa;JPEG 640x480" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="80" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="pubsub" value="Pub/Sub&#xa;frames-in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="80" width="120" height="65" as="geometry" />
        </mxCell>
        <mxCell id="gcp" value="GCP Detection&#xa;Pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="180" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Cloudflare & browser -->
        <mxCell id="cf" value="Cloudflare Tunnel&#xa;(cloudflared)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="270" width="150" height="55" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="Browser Dashboard&#xa;WebRTC Player" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="270" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="ec1" value="USB" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="cam1" target="rtspin" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="cam2" target="rtspin" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="cam3" target="rtspin" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec4" value="RTSP pull" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="rtspout" target="fe" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec5" value="publish" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="fe" target="pubsub" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="pubsub" target="gcp" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec7" value="WHEP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="webrtc" target="cf" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ec8" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="cf" target="browser" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="Two parallel paths:&#xa;(1) RTSP → Frame Extractor → Pub/Sub → GCP inference&#xa;(2) WebRTC → Cloudflare → Browser (live view)" style="text;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=10;spacingLeft=6;spacingTop=4;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="30" y="400" width="500" height="55" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
