<mxfile host="app.diagrams.net" modified="2026-04-06" version="21.0.0">
  <diagram name="Judge Container Lifecycle" id="judge-lifecycle">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="585" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="jc-title" value="judge Container — Build and Runtime Lifecycle" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="10" width="600" height="25" as="geometry" />
        </mxCell>

        <!-- BUILD PHASE -->
        <mxCell id="jc-build" value="Build Phase — GitHub Actions (docker-judge.yml)" style="swimlane;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;fontStyle=1;startSize=26;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="50" width="760" height="155" as="geometry" />
        </mxCell>
        <mxCell id="jc-base" value="Base Image&#xa;pytorch/pytorch&#xa;cuda12.1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="jc-build">
          <mxGeometry x="20" y="45" width="155" height="70" as="geometry" />
        </mxCell>
        <mxCell id="jc-deps" value="Install Deps&#xa;ultralytics, opencv&#xa;google-cloud-pubsub" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="jc-build">
          <mxGeometry x="210" y="45" width="155" height="70" as="geometry" />
        </mxCell>
        <mxCell id="jc-model" value="Download Model&#xa;best.pt (YOLOv8)&#xa;from GCS bucket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="jc-build">
          <mxGeometry x="400" y="45" width="155" height="70" as="geometry" />
        </mxCell>
        <mxCell id="jc-push" value="Tag &amp; Push&#xa;judge:{sha}&#xa;to Artifact Registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="jc-build">
          <mxGeometry x="590" y="45" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="jc-b1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="jc-base" target="jc-deps" parent="jc-build"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="jc-b2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="jc-deps" target="jc-model" parent="jc-build"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="jc-b3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="jc-model" target="jc-push" parent="jc-build"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ARTIFACT REGISTRY -->
        <mxCell id="jc-ar" value="Artifact Registry&#xa;judge:{sha} / judge:latest" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=8;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="319" y="222" width="200" height="60" as="geometry" />
        </mxCell>

        <mxCell id="jc-cross1" value="push" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;strokeWidth=2;" edge="1" source="jc-push" target="jc-ar" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- RUNTIME PHASE -->
        <mxCell id="jc-runtime" value="Runtime Phase — Vertex AI Endpoint" style="swimlane;fillColor=#f5f5f5;strokeColor=#999999;fontSize=12;fontStyle=1;startSize=26;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="305" width="760" height="240" as="geometry" />
        </mxCell>
        <mxCell id="jc-pull" value="Pull Image&#xa;from Artifact Registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="jc-runtime">
          <mxGeometry x="20" y="45" width="155" height="60" as="geometry" />
        </mxCell>
        <mxCell id="jc-load" value="Load Model&#xa;YOLO('best.pt')&#xa;on T4 GPU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="jc-runtime">
          <mxGeometry x="210" y="45" width="155" height="60" as="geometry" />
        </mxCell>
        <mxCell id="jc-serve" value="Serve HTTP :8080&#xa;POST /predict&#xa;GET /healthz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="jc-runtime">
          <mxGeometry x="400" y="45" width="155" height="60" as="geometry" />
        </mxCell>
        <mxCell id="jc-infer" value="Inference Loop&#xa;Decode JPEG → YOLOv8 detect&#xa;→ labels + boxes + confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="jc-runtime">
          <mxGeometry x="210" y="150" width="280" height="65" as="geometry" />
        </mxCell>
        <mxCell id="jc-publish" value="Publish Result&#xa;→ Pub/Sub&#xa;detections-out" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="jc-runtime">
          <mxGeometry x="590" y="150" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="jc-r1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="jc-pull" target="jc-load" parent="jc-runtime"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="jc-r2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="jc-load" target="jc-serve" parent="jc-runtime"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="jc-r3" value="on request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=9;" edge="1" source="jc-serve" target="jc-infer" parent="jc-runtime"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="jc-r4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="jc-infer" target="jc-publish" parent="jc-runtime"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="jc-cross2" value="deploy" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=10;strokeWidth=2;dashed=1;" edge="1" source="jc-ar" target="jc-pull" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
