rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /alerts/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /inferences/{doc} {
      allow read: if true;
      allow write: if false;
    }
    match /system_state/{doc} {
      allow read, write: if true;
    }
  }
}
